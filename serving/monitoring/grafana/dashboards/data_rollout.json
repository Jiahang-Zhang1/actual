{
  "title": "Data Quality & Rollout",
  "uid": "actual-ml-data-rollout",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "tags": ["actual", "ml", "rollout"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "What this dashboard answers",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "mode": "markdown",
        "content": "Operations view for data gates and rollout safety. Use it to justify promotion/rollback decisions: data quality must pass, latency/errors must stay safe, and feedback acceptance must meet thresholds."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Data Gate Pass",
      "description": "1 means the latest check for each stage passed.",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "actual_data_quality_pass",
          "refId": "A",
          "legendFormat": "{{stage}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Data Issues",
      "description": "Issue count from ingestion, training-set, or online-drift checks.",
      "gridPos": {
        "x": 6,
        "y": 3,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "actual_data_quality_issue_count",
          "refId": "A",
          "legendFormat": "{{stage}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Online Drift Score",
      "description": "Alert threshold is drift score > 0.20.",
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "actual_data_quality_metric{stage=\"online_drift\",metric=\"drift_score\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Firing Rollout Alerts",
      "description": "Any nonzero value means check alert details in Prometheus.",
      "gridPos": {
        "x": 18,
        "y": 3,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\",alertname=~\"Smartcat.*\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Rollout KPIs",
      "description": "Serving SLOs used by promotion and rollback triggers.",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smartcat:p95_latency_ms_5m",
          "refId": "A",
          "legendFormat": "p95 latency ms"
        },
        {
          "expr": "100 * smartcat:error_rate_5m",
          "refId": "B",
          "legendFormat": "error rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Feedback Gates",
      "description": "Rollback thresholds: Top-1 < 0.45 or Top-3 < 0.70 with enough feedback.",
      "gridPos": {
        "x": 12,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smartcat:top1_acceptance_1h",
          "refId": "A",
          "legendFormat": "top1"
        },
        {
          "expr": "smartcat:top3_acceptance_1h",
          "refId": "B",
          "legendFormat": "top3"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Data Quality Metrics",
      "description": "Numeric data quality signals posted by ingestion/training/online drift jobs.",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "actual_data_quality_metric",
          "refId": "A",
          "legendFormat": "{{stage}} {{metric}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    }
  ]
}
