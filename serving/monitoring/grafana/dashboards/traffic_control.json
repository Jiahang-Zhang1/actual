  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "How to read this traffic dashboard",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 4
      },
      "options": {
        "mode": "markdown",
        "content": "Use this page when demo traffic or week-long simulated traffic is running. **Live traffic** counts real `/predict` and `/predict_batch` requests used for promotion/rollback decisions. **Synthetic traffic** is load-test traffic marked by headers and excluded from live decision windows. Safe demo state: serving up = 1, p95 < 100 ms for promotion readiness, p95 < 250 ms for rollback safety, 5xx < 1%, and HPA desired replicas stays within 1-5."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Serving scrape is up",
      "description": "1 means Prometheus is scraping the SmartCat serving pod.",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "max(up{job=\"smartcat-serving\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Live request rate",
      "description": "Only real decision-window traffic: /predict and /predict_batch.",
      "gridPos": {
        "x": 4,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smartcat:request_rate_5m",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Synthetic load rate",
