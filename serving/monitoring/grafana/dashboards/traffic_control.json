      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "p95 latency gate",
      "description": "Promotion target <= 100 ms; rollback danger > 250 ms.",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smartcat:p95_latency_ms_5m",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 250
              }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "5xx error gate",
      "description": "Promotion target <= 1%; rollback danger > 2%.",
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smartcat:error_rate_5m",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
