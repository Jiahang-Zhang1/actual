                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.02
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "HPA desired replicas",
      "description": "How many SmartCat pods Kubernetes wants for current load.",
      "gridPos": {
        "x": 20,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "max(kube_horizontalpodautoscaler_status_desired_replicas{namespace=\"smartcat\",horizontalpodautoscaler=\"smartcat-hpa\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Traffic split: live vs synthetic",
      "description": "Live traffic drives promotion/rollback. Synthetic traffic proves load handling without contaminating live feedback windows.",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smartcat:request_rate_5m",
          "legendFormat": "live decision traffic",
          "refId": "A"
        },
        {
          "expr": "sum(rate(synthetic_request_total[5m]))",
          "legendFormat": "synthetic/test traffic",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_requests_total{handler=~\"/predict|/predict_batch\",status=\"2xx\"}[5m]))",
          "legendFormat": "all successful API traffic",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Latency and error safety gates",
      "description": "The green line should stay below 100 ms for promotion readiness and below 250 ms for rollback safety; error rate should stay near zero.",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smartcat:p50_latency_ms_5m",
          "legendFormat": "p50 latency ms",
          "refId": "A"
        },
        {
          "expr": "smartcat:p95_latency_ms_5m",
          "legendFormat": "p95 latency ms",
          "refId": "B"
        },
        {
          "expr": "100 * smartcat:error_rate_5m",
          "legendFormat": "5xx error %",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Autoscaling: current vs desired pods",
      "description": "Shows whether Kubernetes HPA is asking for more SmartCat serving pods under load.",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "max(kube_horizontalpodautoscaler_status_current_replicas{namespace=\"smartcat\",horizontalpodautoscaler=\"smartcat-hpa\"})",
          "legendFormat": "current replicas",
          "refId": "A"
        },
        {
          "expr": "max(kube_horizontalpodautoscaler_status_desired_replicas{namespace=\"smartcat\",horizontalpodautoscaler=\"smartcat-hpa\"})",
          "legendFormat": "desired replicas",
          "refId": "B"
        },
        {
          "expr": "sum(kube_deployment_status_replicas_available{namespace=\"smartcat\",deployment=\"smartcat-serving\"})",
          "legendFormat": "available pods",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Serving CPU under load",
      "description": "CPU rising while latency stays safe is the expected scaling story.",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"smartcat\",pod=~\"smartcat-serving-.*\",container!=\"POD\"}[5m]))",
          "legendFormat": "CPU cores used",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Request mix by endpoint",
      "description": "Confirms traffic hits /predict and /predict_batch rather than only health checks.",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (handler) (increase(http_requests_total{handler=~\"/predict|/predict_batch\"}[$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "values": true,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      }
    },
