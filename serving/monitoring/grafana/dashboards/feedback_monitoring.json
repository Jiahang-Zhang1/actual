{
  "title": "Feedback Monitoring",
  "uid": "smartcat-feedback",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Feedback events per second",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(feedback_total[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Top1 / Top3 acceptance rate",
      "gridPos": { "x": 8, "y": 0, "w": 16, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(feedback_match_total[5m])) / clamp_min(sum(rate(feedback_total[5m])), 1e-9)",
          "legendFormat": "top1",
          "refId": "A"
        },
        {
          "expr": "sum(rate(feedback_top3_match_total[5m])) / clamp_min(sum(rate(feedback_total[5m])), 1e-9)",
          "legendFormat": "top3",
          "refId": "B"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Top1 acceptance (1h)",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum(increase(feedback_match_total[1h])) / clamp_min(sum(increase(feedback_total[1h])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Top3 acceptance (1h)",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum(increase(feedback_top3_match_total[1h])) / clamp_min(sum(increase(feedback_total[1h])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Feedback volume (1h)",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum(increase(feedback_total[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Selected categories (range)",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (selected_category_id) (increase(feedback_total[$__range]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Promotion/Rollback KPIs (1h)",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(increase(feedback_total[1h]))",
          "legendFormat": "feedback_volume_1h",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "sum(increase(feedback_match_total[1h])) / clamp_min(sum(increase(feedback_total[1h])), 1e-9)",
          "legendFormat": "top1_acceptance_1h",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "sum(increase(feedback_top3_match_total[1h])) / clamp_min(sum(increase(feedback_total[1h])), 1e-9)",
          "legendFormat": "top3_acceptance_1h",
          "format": "table",
          "instant": true,
          "refId": "C"
        }
      ]
    }
  ]
}
