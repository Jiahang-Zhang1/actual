{
  "title": "Prediction Monitoring",
  "uid": "smartcat-prediction",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Average confidence",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(prediction_confidence_sum[1m])) / clamp_min(sum(rate(prediction_confidence_count[1m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Predicted classes (selected range)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 10 },
      "targets": [
        {
          "expr": "increase(predicted_class_total[$__range])",
          "legendFormat": "{{category_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Prediction throughput (items/s)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(predicted_class_total[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Low-confidence ratio (<=0.4, 5m)",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(prediction_confidence_bucket{le=\"0.4\"}[5m])) / clamp_min(sum(rate(prediction_confidence_count[5m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Predicted category counts (range)",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum by (category_id) (increase(predicted_class_total[$__range]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ]
}
