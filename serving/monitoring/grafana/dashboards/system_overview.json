{
  "title": "Actual ML System Overview",
  "uid": "actual-ml-system-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "tags": [
    "actual",
    "ml",
    "overview"
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "What this dashboard answers",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "mode": "markdown",
        "content": "One-screen health check for the integrated demo. Use this during the defense to show that serving is up, traffic is flowing, latency/error SLOs are safe, and model feedback is being captured."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Serving Up",
      "description": "1 means Prometheus can scrape the serving container.",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "max(up{job=\"smartcat-serving\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Request Rate",
      "description": "Predict and predict_batch requests per second.",
      "gridPos": {
        "x": 4,
        "y": 3,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smartcat:request_rate_5m",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p95 Latency",
      "description": "Rollback threshold is 250 ms; promotion threshold is 100 ms.",
      "gridPos": {
        "x": 8,
        "y": 3,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smartcat:p95_latency_ms_5m",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "5xx Error Rate",
      "description": "Rollback threshold is 2%; promotion threshold is 1.",
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smartcat:error_rate_5m",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Feedback Volume",
      "description": "Enough feedback is required before promotion/rollback decisions.",
      "gridPos": {
        "x": 16,
        "y": 3,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(feedback_total[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Data Quality",
      "description": "1 means all recent data quality gates passed.",
      "gridPos": {
        "x": 20,
        "y": 3,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smartcat:data_quality_pass_min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Traffic and Latency",
      "description": "Traffic should rise during simulated user testing; p95 should remain below rollback threshold.",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smartcat:request_rate_5m",
          "refId": "A",
          "legendFormat": "requests/s"
        },
        {
          "expr": "smartcat:p95_latency_ms_5m",
          "refId": "B",
          "legendFormat": "p95 ms"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Feedback Acceptance",
      "description": "Top-3 acceptance is the core product-quality signal for suggestions.",
      "gridPos": {
        "x": 12,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smartcat:top1_acceptance_1h",
          "refId": "A",
          "legendFormat": "top1"
        },
        {
          "expr": "smartcat:top3_acceptance_1h",
          "refId": "B",
          "legendFormat": "top3"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "Predicted Category Mix",
      "description": "Shows whether model output is diverse or collapsing to one class.",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(10, sum by (category_id) (increase(predicted_class_total[$__range])))",
          "refId": "A",
          "legendFormat": "{{category_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Firing Alerts",
      "description": "Should stay at 0 in a healthy demo.",
      "gridPos": {
        "x": 12,
        "y": 15,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\",alertname=~\"Smartcat.*\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Low Confidence Ratio",
      "description": "Share of predictions with confidence <= 0.4.",
      "gridPos": {
        "x": 18,
        "y": 15,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smartcat:low_confidence_ratio_5m",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {}
    }
  ]
}