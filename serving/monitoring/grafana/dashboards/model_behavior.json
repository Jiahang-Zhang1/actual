{
  "title": "Model Behavior",
  "uid": "actual-ml-model-behavior",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "tags": ["actual", "ml", "model"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "What this dashboard answers",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "mode": "markdown",
        "content": "Model-focused view. Use it to explain output distribution, confidence, Top-1/Top-3 user acceptance, and whether predictions are useful enough to keep or promote."
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Average Confidence",
      "description": "Mean prediction confidence over time.",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smartcat:avg_confidence_5m",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Low Confidence Ratio",
      "description": "Rising low-confidence share can indicate drift or weak training data.",
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smartcat:low_confidence_ratio_5m",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Prediction Throughput",
      "description": "Predicted transaction items per second.",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(predicted_class_total[1m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "ips"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Top Predicted Categories",
      "description": "Top predicted categories in the selected time window.",
      "gridPos": {
        "x": 8,
        "y": 11,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(10, sum by (category_id) (increase(predicted_class_total[$__range])))",
          "refId": "A",
          "legendFormat": "{{category_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Top-1 vs Top-3 Acceptance",
      "description": "Top-3 acceptance is expected to be higher and drives rollout safety.",
      "gridPos": {
        "x": 16,
        "y": 11,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smartcat:top1_acceptance_1h",
          "refId": "A",
          "legendFormat": "top1"
        },
        {
          "expr": "smartcat:top3_acceptance_1h",
          "refId": "B",
          "legendFormat": "top3"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {}
    }
  ]
}
